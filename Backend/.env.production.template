# ─── ExtractIQ Production Environment Template ───
# Copy to Backend/.env and fill in all values before deploying.
# NEVER commit this file with real secrets.

# ── Application ──
NODE_ENV=production
LOG_LEVEL=info
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=https://your-domain.com

# ── PostgreSQL ──
POSTGRES_USER=mcq_user
POSTGRES_PASSWORD=          # REQUIRED: Strong random password (32+ chars)
POSTGRES_DB=mcq_platform
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ──
REDIS_PASSWORD=             # REQUIRED: Strong random password (32+ chars)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ── MinIO / S3 ──
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=              # REQUIRED: MinIO access key
S3_SECRET_KEY=              # REQUIRED: MinIO secret key (32+ chars)
S3_BUCKET=mcq-platform
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── Authentication ──
JWT_SECRET=                 # REQUIRED: Random 64-char hex string (openssl rand -hex 32)
JWT_EXPIRY=24h
BCRYPT_ROUNDS=12

# ── Encryption ──
ENCRYPTION_KEY=             # REQUIRED: 64-char hex string for AES-256-GCM (openssl rand -hex 32)

# ── AI Providers (configure via UI or set here) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
QWEN_VL_ENDPOINT=
QWEN_VL_API_KEY=
GLM_OCR_ENDPOINT=
GLM_OCR_API_KEY=

# ── Rate Limiting ──
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000

# ── File Upload ──
MAX_FILE_SIZE_MB=50
PRESIGNED_UPLOAD_TTL_SECONDS=900
PRESIGNED_DOWNLOAD_TTL_SECONDS=3600
