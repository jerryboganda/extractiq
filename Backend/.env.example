# ─── Application ───
NODE_ENV=development
LOG_LEVEL=debug

# ─── API Server ───
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:8080
APP_BASE_URL=http://localhost:8080/app

# ─── Database (PostgreSQL 16) ───
DATABASE_URL=postgresql://mcq_user:mcq_password@localhost:5432/mcq_platform
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible) ───
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mcq-platform
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─── Authentication ───
JWT_SECRET=change-me-to-a-secure-random-string-at-least-64-chars-long-for-production
JWT_EXPIRY=24h
BCRYPT_ROUNDS=12

# ─── Encryption (for provider API keys at rest) ───
ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key-00000000

# ─── AI Providers ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=

# Qwen VL (self-hosted or API)
QWEN_VL_ENDPOINT=
QWEN_VL_API_KEY=

# GLM-OCR
GLM_OCR_ENDPOINT=
GLM_OCR_API_KEY=

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key
SMTP_SECURE=false
SMTP_FROM_NAME=ExtractIQ Document Intelligence
SMTP_FROM=noreply@extractiq.com
SALES_NOTIFICATION_EMAIL=sales@extractiq.com
SUPPORT_NOTIFICATION_EMAIL=support@extractiq.com
ENABLE_EMAIL_DELIVERY=true

# ─── Rate Limiting ───
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000

# ─── File Upload ───
MAX_FILE_SIZE_MB=50
PRESIGNED_UPLOAD_TTL_SECONDS=900
PRESIGNED_DOWNLOAD_TTL_SECONDS=3600
